                <argument>generateGetters</argument>
                <argument>-c</argument>
                <argument>globalConfig</argument>
                <argument>-r</argument>
                <argument>${generated-zattr}/ZAttrConfig.java</argument>
              </arguments>
            </configuration>
          </execution>
          <execution>
            <id>generate-ZAttrCos</id>
            <phase>generate-sources</phase>
            <goals>
              <goal>java</goal>
            </goals>
            <configuration>
              <mainClass>com.zimbra.cs.account.AttributeManagerUtil</mainClass>
              <arguments>
                <argument>-a</argument>
                <argument>generateGetters</argument>
                <argument>-c</argument>
                <argument>cos</argument>
                <argument>-r</argument>
                <argument>${generated-zattr}/ZAttrCos.java</argument>
              </arguments>
            </configuration>
          </execution>
          <execution>
            <id>generate-ZAttrDomain</id>
            <phase>generate-sources</phase>
            <goals>
              <goal>java</goal>
            </goals>
            <configuration>
              <mainClass>com.zimbra.cs.account.AttributeManagerUtil</mainClass>
              <arguments>
                <argument>-a</argument>
                <argument>generateGetters</argument>
                <argument>-c</argument>
                <argument>domain</argument>
                <argument>-r</argument>
                <argument>${generated-zattr}/ZAttrDomain.java</argument>
              </arguments>
            </configuration>
          </execution>
          <execution>
            <id>generate-ZAttrServer</id>
            <phase>generate-sources</phase>
            <goals>
              <goal>java</goal>
            </goals>
            <configuration>
              <mainClass>com.zimbra.cs.account.AttributeManagerUtil</mainClass>
