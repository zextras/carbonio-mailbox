          <!-- BuildInfo -->
          <execution>
            <id>generate-buildinfo</id>
            <phase>generate-sources</phase>
            <goals>
              <goal>exec</goal>
            </goals>
            <configuration>
              <executable>/bin/bash</executable>
              <arguments>
                <argument>-c</argument>
                <argument><![CDATA[
                  mkdir -p ${generated-resources}/com/zimbra/cs/util/ && cat <<EOF > ${generated-resources}/com/zimbra/cs/util/buildInfo.properties
MAJORVERSION=${parsedVersion.majorVersion}
MINORVERSION=${parsedVersion.minorVersion}
MICROVERSION=${parsedVersion.incrementalVersion}
RELCLASS=ZEXTRAS
RELNUM=0
BUILDNUM=${build.timestamp.yyyymm}
VERSION=${parsedVersion.majorVersion}.${parsedVersion.minorVersion}.${parsedVersion.incrementalVersion}_ZEXTRAS_${build.timestamp.yyyymm}
RELEASE=carbonio
DATE=${build.timestamp.yyyymm}
HOST=carbonio
EOF
                ]]></argument>
              </arguments>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <!-- Add buildinfo sources -->
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>build-helper-maven-plugin</artifactId>
        <version>3.0.0</version>
        <executions>
          <execution>
            <id>parse-version</id>
            <goals>
              <goal>parse-version</goal>
            </goals>
            <phase>validate</phase>
            <configuration>
              <propertyPrefix>parsedVersion</propertyPrefix>
            </configuration>
          </execution>
          <execution>
            <id>add-timestamp</id>
            <goals>
              <goal>timestamp-property</goal>
            </goals>
            <phase>initialize</phase>
            <configuration>
              <name>build.timestamp.yyyymm</name>
              <pattern>yyyyMM</pattern>
            </configuration>
          </execution>
          <execution>
            <phase>generate-sources</phase>
            <goals>
              <goal>add-source</goal>
            </goals>
            <configuration>
              <sources>
                <source>${project.build.directory}/generated-sources/buildinfo</source><!-- adjust
                folder name to your needs -->
                <source>${project.build.directory}/generated-sources/javacc</source>
                <source>${project.build.directory}/generated-sources/zattr</source>
              </sources>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>flatten-maven-plugin</artifactId>
      </plugin>

      <!-- Test plugin execution -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <configuration>
          <forkCount>1</forkCount>
          <reuseForks>true</reuseForks>
          <argLine>@{argLine} --enable-native-access=ALL-UNNAMED -Xmx2g -Dserver.dir=${project.basedir}
            -Dzimbra.config=${project.basedir}/src/test/resources/localconfig-test.xml
            -Dlog4j.configurationFile=${project.basedir}/src/test/resources/log4j-test.properties
            -Dfile.encoding=UTF-8 -Djava.locale.providers=CLDR,SPI
          </argLine>
          <environmentVariables>
            <LC_ALL>C.UTF-8</LC_ALL>
          </environmentVariables>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-failsafe-plugin</artifactId>
        <configuration>
          <forkCount>1</forkCount>
          <reuseForks>true</reuseForks>
          <argLine>@{argLine} --enable-native-access=ALL-UNNAMED -Xmx2g -Dserver.dir=${project.basedir}
            -Dlog4j.configurationFile=${project.basedir}/src/test/resources/log4j-test.properties
            -Dzimbra.config=${project.basedir}/src/test/resources/localconfig-test.xml
            -Dfile.encoding=UTF-8 -Djava.locale.providers=CLDR,SPI
          </argLine>
          <environmentVariables>
            <LC_ALL>C.UTF-8</LC_ALL>
          </environmentVariables>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
      </plugin>

      <plugin>
        <groupId>io.swagger.core.v3</groupId>
        <artifactId>swagger-maven-plugin</artifactId>
        <version>${swagger.version}</version>
        <configuration>
          <outputFileName>internal-api-openapi</outputFileName>
          <outputPath>${project.basedir}</outputPath>
          <outputFormat>YAML</outputFormat>
          <resourcePackages>
            <resourcePackage>com.zextras.mailbox.api.rest.resource</resourcePackage>
          </resourcePackages>
          <configurationFilePath>${project.basedir}/src/main/resources/openapi-configuration.json</configurationFilePath>
        </configuration>
        <executions>
          <execution>
            <phase>compile</phase>
            <goals>
              <goal>resolve</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.3.0</version>
        <configuration>
          <archive>
            <manifest>
              <mainClass>com.zextras.mailbox.Mailbox</mainClass>
            </manifest>
          </archive>
        </configuration>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>test-jar</goal>
            </goals>
            <configuration>
              <includes>
                <include>com/zimbra/cs/db/HSQLDB*</include>
                <include>com/zextras/mailbox/util/InMemoryLdapServer*</include>
                <include>**/*.ldif</include>
                <include>com/zimbra/cs/db/*.sql</include>
              </includes>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-dependency-plugin</artifactId>
        <executions>
          <execution>
            <id>copy-dependencies</id>
            <phase>package</phase>
            <goals>
              <goal>copy-dependencies</goal>
            </goals>
            <configuration>
              <outputDirectory>${project.build.directory}/dependencies</outputDirectory>
              <includeScope>compile</includeScope>
              <includeScope>runtime</includeScope>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-source-plugin</artifactId>
        <version>3.3.1</version>
        <executions>
          <execution>
            <id>attach-sources</id>
            <phase>verify</phase>
            <goals>
              <goal>jar-no-fork</goal>
              <goal>test-jar-no-fork</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>javacc-maven-plugin</artifactId>
        <version>3.1.0</version>
        <executions>
          <execution>
            <id>generate-parser-jjtree</id>
            <goals>
              <goal>jjtree</goal>
            </goals>
            <configuration>
              <sourceDirectory>${project.basedir}/src/main/java</sourceDirectory>
              <outputDirectory>${project.build.directory}/generated-sources/javacc</outputDirectory>
              <includes>
                <include>**/Parser.jjt</include>
              </includes>
            </configuration>
          </execution>
          <execution>
            <id>generate-parser-javacc</id>
            <goals>
              <goal>javacc</goal>
            </goals>
            <configuration>
              <sourceDirectory>${project.build.directory}/generated-sources/javacc</sourceDirectory>
              <outputDirectory>${project.build.directory}/generated-sources/javacc</outputDirectory>
              <includes>
                <include>**/Parser.jj</include>
              </includes>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>

  </build>
  <properties>
    <build.dir>target</build.dir>
    <maven-exec-plugin.version>3.1.0</maven-exec-plugin.version>
    <maven-clean-plugin.version>3.1.0</maven-clean-plugin.version>
    <generated-sources>${project.build.directory}/generated-sources</generated-sources>
    <generated-zattr>${generated-sources}/zattr/com/zimbra/cs/account</generated-zattr>
    <generated-resources>${project.build.directory}/generated-resources</generated-resources>
  </properties>

</project>
